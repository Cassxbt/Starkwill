{
  "name": "ss-2",
  "version": "2.1.0",
  "author": "Q3 Labs",
  "license": "MIT",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/snfoundry",
      "packages/nextjs"
    ]
  },
  "overrides": {
    "chalk": "5.3.0",
    "strip-ansi": "7.1.0",
    "color-convert": "2.0.1",
    "color-name": "1.1.4",
    "is-core-module": "2.13.1",
    "error-ex": "1.3.2",
    "has-ansi": "5.0.1"
  },
  "scripts": {
    "chain": "npm run chain --workspace=@ss-2/snfoundry",
    "deploy": "npm run deploy --workspace=@ss-2/snfoundry",
    "deploy:clear": "npm run deploy:clear --workspace=@ss-2/snfoundry",
    "deploy:no-reset": "npm run deploy:no-reset --workspace=@ss-2/snfoundry",
    "test": "npm run test --workspace=@ss-2/snfoundry",
    "compile": "npm run compile --workspace=@ss-2/snfoundry",
    "start": "npm run dev --workspace=@ss-2/nextjs",
    "next:lint": "npm run lint --workspace=@ss-2/nextjs",
    "next:check-types": "npm run check-types --workspace=@ss-2/nextjs",
    "build:nextjs": "npm run build --workspace=@ss-2/nextjs",
    "vercel": "npm run vercel --workspace=@ss-2/nextjs",
    "vercel:yolo": "npm run vercel:yolo --workspace=@ss-2/nextjs",
    "test:nextjs": "npm run test --workspace=@ss-2/nextjs",
    "format": "npm run format --workspace=@ss-2/nextjs && npm run format --workspace=@ss-2/snfoundry",
    "format:check": "npm run format:check --workspace=@ss-2/nextjs && npm run format:check --workspace=@ss-2/snfoundry",
    "prepare": "husky || true",
    "verify": "npm run verify --workspace=@ss-2/snfoundry",
    "clean": "npm run clean --workspace=@ss-2/snfoundry"
  },
  "devDependencies": {
    "daisyui": "latest",
    "husky": "^9.0.11",
    "pinst": "^3.0.0",
    "prettier": "^3.2.5"
  },
  "dependencies": {
    "postcss": "^8.4.38"
  }
}
